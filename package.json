{
  "name": "retirement-forecast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first UK retirement drawdown & tax planner",
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"tsx server/index.ts\" \"vite\"",
    "server": "tsx server/index.ts",
    "build": "tsc -b && tsc -p server/tsconfig.json && vite build",
    "preview": "concurrently -k -n api,web -c blue,green \"tsx server/index.ts\" \"vite preview\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "msnodesqlv8": "^5.2.1",
    "mssql": "^12.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/mssql": "^12.3.0",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.23.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
